# Template only — Next.js does NOT read this file at runtime.
# Copy to `.env.local` and put real values there only. Never commit `.env.local`.
#
# --- Supabase (https://supabase.com/dashboard) ---
# Project URL and anon key are safe to expose to the browser (RLS still applies).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: used for privileged operations (e.g. /api/send-alerts scanning all due tasks).
# Never expose to the client. Keep in Vercel Environment Variables only.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Gemini (@google/generative-ai) ---
# https://aistudio.google.com/apikey — free tier, no card for AI Studio keys.
GEMINI_API_KEY=
# Optional override (default in code: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
# Claude API key from console.anthropic.com — uses claude-haiku-4-5 model
ANTHROPIC_API_KEY=
# Optional free-tier fallback provider (https://openrouter.ai/)
# Example free model: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# Optional free-tier fallback provider (https://console.groq.com/)
# Keep to allowlisted free models enforced in code.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Per-provider timeout before failing over to next provider.
LLM_PROVIDER_TIMEOUT_MS=12000
# Hard stop for free-tier usage (per user, per schedule_date)
FREE_DAILY_GENERATION_LIMIT=20

# --- Telegram Bot (https://t.me/BotFather) ---
TELEGRAM_BOT_TOKEN=
# Optional: bot @handle without @. If omitted, the app looks it up via getMe using the token above.
TELEGRAM_BOT_USERNAME=
# Optional: only if you register POST /api/telegram/webhook (one-tap Connect). Reminders + manual chat ID work without it.
TELEGRAM_WEBHOOK_SECRET=
# --- App URL (used in Telegram deep links or absolute URLs if needed) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- External cron (cron-job.org) → GET/POST /api/send-alerts every 5 minutes ---
# Send the same value as Authorization: Bearer <CRON_SECRET> from cron-job.org.
# Prevents random visitors from triggering alert sends on the Hobby deployment.
CRON_SECRET=
