# Copy to .env.local for local development. Next.js does not read this file at runtime.

# --- Supabase (https://supabase.com/dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never expose to the browser (cron, Telegram webhook).
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL ---
# Local: http://localhost:3000 — Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Telegram (@BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Required in production when NEXT_PUBLIC_APP_URL is public HTTPS (one-tap connect).
TELEGRAM_WEBHOOK_SECRET=

# --- Reminders (GET/POST /api/send-alerts) ---
# Vercel Cron (vercel.json) sends Authorization: Bearer <CRON_SECRET> automatically.
# Local check: npm run test:alerts
CRON_SECRET=

# --- AI providers (at least one required for schedule generation) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER_TIMEOUT_MS=12000
FREE_DAILY_GENERATION_LIMIT=20
